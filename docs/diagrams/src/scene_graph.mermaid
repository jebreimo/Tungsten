classDiagram
namespace SceneSide {
    class Scene {
        +roots: vector~Node~
        +snapshots: DoubleBuffer~RenderSnapshot~
        +add(node: Node)
        +remove(node: Node)
        +update(dt: float)
    }

    class Node {
        +local_transform: Transform
        +children: vector~Node~
        +parent: Node*
        +components: vector~Component~
        -world_matrix: mat4
        -world_version: uint64
        -parent_version_seen: uint64
        -local_dirty: bool
        +world_bounds: AABB
        +world_matrix(): mat4
        +add_child(node: Node)
        +remove_child(node: Node)
        +reparent(new_parent: Node)
        +mark_local_dirty()
    }

    class Transform {
        +translation: vec3
        +rotation: quat
        +scale: vec3
        -local_matrix: mat4
        -local_dirty: bool
        +local_matrix(): mat4
        +mark_dirty()
    }

    class Component {
        <<abstract>>
        +owner: Node*
    }

    class RenderableComponent {
        +mesh: MeshRef
        +material: MaterialRef
        +local_bounds: AABB
        +visible: bool
        +render_layer: uint32_t
    }

    class CameraComponent {
        +mode: ProjectionMode
        +fov: float
        +near: float
        +far: float
        +ortho_size: float
        +get_view_matrix(): mat4
        +get_projection_matrix(): mat4
    }

    class ProjectionMode {
        <<enumeration>>
        PERSPECTIVE
        ORTHOGRAPHIC
    }

    class LightComponent {
        +type: LightType
        +color: vec3
        +intensity: float
        +range: float
    }

    class TransformUpdater {
        +resolve(scene: Scene)
        -resolve_node(node: Node)
        -propagate_bounds(node: Node)
    }
}

namespace Bridge {
    class ResourceRef~T~ {
        +index: uint32_t
        +generation: uint32_t
    }

    class SnapshotBuilder {
        +build(scene: Scene, camera: CameraComponent, out: RenderSnapshot)
        -extract_item(node: Node, component: RenderableComponent): RenderItem
        -cull(camera: CameraComponent, bounds: AABB): bool
        -compute_sort_key(item: RenderItem): uint64
        -compute_normal_matrix(world: mat4): mat3
    }

    class DoubleBuffer~T~ {
        +back(): T
        +front(): T
        +swap()
    }

    class RenderSnapshot {
        +opaque_items: vector~RenderItem~
        +transparent_items: vector~RenderItem~
        +view_matrix: mat4
        +projection_matrix: mat4
        +lights: vector~LightData~
        +time: float
    }

    class RenderItem {
        +world_transform: mat4
        +normal_matrix: mat3
        +mesh: MeshRef
        +material: MaterialRef
        +sort_key: uint64_t
        +world_bounds: AABB
    }

    class LightData {
        +type: LightType
        +position: vec3
        +direction: vec3
        +color: vec3
        +intensity: float
        +range: float
    }
}

namespace ResourceSide {
    class ResourceManager {
        +create_arena(usage: BufferUsage, stride: uint16, capacity: uint32): BufferArenaRef
        +get_arena(ref: BufferArenaRef): BufferArena
        +destroy_arena(ref: BufferArenaRef)
        +allocate(ref: BufferArenaRef, count: uint32): SharedBuffer
        +free(slice: SharedBuffer)
        +register_layout(layout: VertexLayout): VertexLayoutRef
        +get_layout(ref: VertexLayoutRef): VertexLayout
        +create_mesh(mesh: Mesh): MeshRef
        +get_mesh(ref: MeshRef): Mesh
        +destroy_mesh(ref: MeshRef)
        +create_material(material: Material): MaterialRef
        +get_material(ref: MaterialRef): Material
        +destroy_material(ref: MaterialRef)
        +create_texture(texture: Texture): TextureRef
        +get_texture(ref: TextureRef): Texture
        +destroy_texture(ref: TextureRef)
        +register_shader_family(id: ShaderFamilyId, family: ShaderFamily)
        +register_shader_variant(key: ShaderVariantKey): ShaderProgramRef
        +get_shader(ref: ShaderProgramRef): ShaderProgram
        +get_vao(vbo_arenas: BufferArenaRef[], ebo_arena: BufferArenaRef, layout: VertexLayoutRef): uint32
        +begin_frame(frame: uint64_t)
        +collect_garbage(completed_frame: uint64_t)
        -arenas: GenerationalPool
        -meshes: GenerationalPool
        -materials: GenerationalPool
        -shaders: GenerationalPool
        -textures: GenerationalPool
        -layout_registry: LayoutRegistry
        -vao_cache: VaoCache
        -shader_library: ShaderLibrary
        -deletions: DeletionQueue
    }

    class GenerationalPool {
        -slots: Slot[]
        -free_list: uint32_t[]
        +insert(value: resource): ResourceRef
        +get(ref: ResourceRef): resource
        +erase(ref: ResourceRef, on_retire)
    }

    class Slot {
        +value: optional
        +generation: uint32_t
    }

    class DeletionQueue {
        -entries: RetiredObject[]
        -current_frame: uint64_t
        +begin_frame(frame: uint64_t)
        +retire(handle: GlHandle)
        +collect_garbage(completed_frame: uint64_t)
    }

    class LayoutRegistry {
        -layouts: VertexLayout[]
        +register_layout(layout: VertexLayout): VertexLayoutRef
        +get_layout(ref: VertexLayoutRef): VertexLayout
    }

    class VaoCache {
        -entries: VaoEntry[]
        +get_vao(vbo_arenas: BufferArenaRef[], ebo_arena: BufferArenaRef, layout: VertexLayoutRef): uint32
        -build_vao(key: VaoKey): uint32
        +rebuild_for_arena(ref: BufferArenaRef)
        +evict_for_arena(ref: BufferArenaRef)
    }

    class ShaderLibrary {
        -families: ShaderFamily[]
        -variant_cache: map
        +register_family(id: ShaderFamilyId, family: ShaderFamily): void
        +register_variant(key: ShaderVariantKey): ShaderProgramRef
    }

    class ShaderVariantKey {
        +family: ShaderFamilyId
        +defines: uint32_t
    }

    class ShaderFamily {
        +id: ShaderFamilyId
        +vertex_source: string
        +fragment_source: string
        +features: string[]
        +required_layout: VertexLayout
    }

    note for ResourceManager "ResourceManager is a thin facade (design section 10): its public methods forward to five GenerationalPool instances (one each for Mesh, Material, ShaderProgram, Texture, BufferArena) and four collaborators (LayoutRegistry, VaoCache, ShaderLibrary, DeletionQueue). Pools and caches retire GL objects into the one DeletionQueue."

    class AttributeSemantic {
        <<enumeration>>
        POSITION
        NORMAL
        TANGENT
        BITANGENT
        TEX_COORD_0
        TEX_COORD_1
        COLOR_0
        BONE_INDICES
        BONE_WEIGHTS
    }

    class VertexAttribute {
        +semantic: AttributeSemantic
        +stream_index: uint8_t
        +type: GLenum
        +component_count: uint8_t
        +normalized: bool
        +offset_in_stream: uint16_t
    }

    class VertexLayout {
        +attributes: vector~VertexAttribute~
        +stride: uint16_t
    }

    class VertexStream {
        +vbo: SharedBuffer
        +first_vertex: uint32_t
        +stride: uint16_t
        +vertex_count: uint32_t
    }

    class IndexType {
        <<enumeration>>
        UNSIGNED_SHORT
        UNSIGNED_INT
    }

    class Mesh {
        +vao: uint32_t
        +streams: vector~VertexStream~
        +layout: VertexLayout
        +ebo: SharedBuffer
        +first_index: uint32_t
        +index_count: uint32_t
        +index_type: IndexType
        +primitive: PrimitiveType
    }

    class SharedBuffer {
        +arena: BufferArenaRef
        +offset: uint32_t
        +count: uint32_t
    }

    class BufferArena {
        +buffer: BufferHandle
        +usage: BufferUsage
        +stride: uint16_t
        -allocator: BuddyAllocator
        +allocate(count: uint32): Allocation
        +free(offset: uint32)
        +grow(min_capacity: uint32)
    }

    class Allocation {
        +offset: uint32_t
        +retired_buffer: BufferHandle
    }

    class BuddyAllocator {
        -capacity: size_t
        +allocate(size: size_t): optional~size_t~
        +free(offset: size_t)
        +claim(offset: size_t, size: size_t): bool
    }

    class Material {
        +shader: ShaderProgramRef
        +parameter_data: vector~uint8_t~
        +textures: vector~TextureRef~
        +id: uint32_t
    }

    class ShaderProgram {
        +gl_handle: ProgramHandle
        +id: uint32_t
        +variant_key: ShaderVariantKey
        +required_layout: VertexLayout
    }

    class Texture {
        +gl_handle: TextureHandle
        +width: uint32_t
        +height: uint32_t
        +format: TextureFormat
    }
}

namespace RenderSide {
    class Renderer {
        +render(snapshot: RenderSnapshot)
        -sort_items(items: RenderItem[])
        -draw_item(item: RenderItem)
        -bind_per_frame(snapshot: RenderSnapshot)
        -bind_material(mat: Material)
        -gl_state_cache: GlStateCache
    }

    class GlStateCache {
        -current_program_: uint32_t
        -current_vao_: uint32_t
        -current_material_ubo_: uint32_t
        -bound_textures_: map
        +use_program(program_id: uint32_t)
        +bind_vao(vao_id: uint32_t)
        +bind_texture(unit: int32_t, texture_id: uint32_t)
        +bind_material_ubo(buffer_id: uint32_t)
        +invalidate()
    }

    class UboBindings {
        <<constants>>
        +PER_FRAME_UBO_BINDING: uint32_t
        +PER_MATERIAL_UBO_BINDING: uint32_t
        +PER_DRAW_UBO_BINDING: uint32_t
    }

    note for UboBindings "Fixed binding points (§4): PER_FRAME = 0, PER_MATERIAL = 1, PER_DRAW = 2"
}

Scene "1" *-- "1..*" Node
Scene "1" *-- "1" DoubleBuffer~T~
Node "1" *-- "1" Transform
Node "1" *-- "0..*" Component
Node "1" *-- "0..*" Node : children
Node "0..*" --> "1" Node : parent (raw)
RenderableComponent --|> Component
CameraComponent --|> Component
LightComponent --|> Component
CameraComponent --> ProjectionMode : uses

TransformUpdater ..> Scene : resolves dirty subtrees
SnapshotBuilder ..> Scene : reads finalized world data
SnapshotBuilder ..> ResourceManager : resolves handles
SnapshotBuilder ..> RenderSnapshot : writes back buffer
GenerationalPool ..> ResourceRef~T~ : keys slots by

DoubleBuffer~T~ "1" *-- "2" RenderSnapshot
RenderSnapshot "1" *-- "0..*" RenderItem
RenderSnapshot "1" *-- "0..*" LightData

Renderer ..> RenderSnapshot : consumes front buffer
Renderer ..> ResourceManager : fetches GL objects
Renderer "1" *-- "1" GlStateCache
Renderer ..> UboBindings : binds per-frame / per-draw blocks
GlStateCache ..> UboBindings : binds per-material block

ResourceManager "1" *-- "5" GenerationalPool : Mesh/Material/Shader/Texture/Arena pools
ResourceManager "1" *-- "1" LayoutRegistry
ResourceManager "1" *-- "1" VaoCache
ResourceManager "1" *-- "1" ShaderLibrary
ResourceManager "1" *-- "1" DeletionQueue
GenerationalPool "1" *-- "0..*" Slot : holds

ResourceManager ..> SharedBuffer : creates (offset + ref)
BufferArena ..> Allocation : returns from allocate
BufferArena "1" *-- "1" BuddyAllocator : manages offsets
SharedBuffer --> BufferArena : references (ref)
Mesh "1" *-- "1..*" VertexStream
Mesh --> VertexLayout : describes
Mesh --> IndexType : uses
Mesh ..> VaoCache : vao id (cached VAO, owned by VaoCache)
VertexLayout "1" *-- "1..*" VertexAttribute
VertexAttribute --> AttributeSemantic : defines

Material --> ShaderProgram : references
Material ..> Texture : samples (TextureRef)
ShaderProgram --> VertexLayout : requires
ShaderProgram --> ShaderVariantKey : compiled for
LayoutRegistry "1" *-- "0..*" VertexLayout : interns
VaoCache ..> BufferArena : resolves + binds
VaoCache ..> DeletionQueue : retires evicted VAOs
ShaderLibrary "1" *-- "0..*" ShaderFamily : registers
ShaderLibrary ..> ShaderVariantKey : keys variant cache
ShaderLibrary ..> ShaderProgram : compiles into pool
ShaderFamily --> VertexLayout : requires
RenderableComponent --> Mesh : ref
RenderableComponent --> Material : ref
